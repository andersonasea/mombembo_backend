# Runtime (requêtes API) — pooler transactionnel Supabase (port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD-URL-ENCODED]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Migrations Prisma CLI — connexion directe (Supabase → Settings → Database → Direct)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD-URL-ENCODED]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"
# Dev local : vous pouvez utiliser le session pooler (5432) pour les deux si DIRECT_URL est absent
JWT_SECRET="replace-with-a-strong-secret"
API_PORT=4000
FRONTEND_ORIGIN="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000,https://ton-frontend.com"
PUBLIC_API_BASE_URL="http://localhost:4000"
# --- FlexPay SANDBOX (tests actuels) — API v1 ---
FLEXPAY_BASE_URL="https://api.gofreshpay.com/api/v1/gateway"
FLEXPAY_MERCHANT_ID="votre-api-key-sandbox-uuid"
FLEXPAY_MERCHANT_SECRET="votre-api-secret-sandbox"

# --- FlexPay PRODUCTION (plus tard) — API v5 PayDRC ---
# FLEXPAY_BASE_URL="https://paydrc.gofreshbakery.net/api/v5/"
# FLEXPAY_MERCHANT_ID="votre-api-key-production-hex"
# FLEXPAY_MERCHANT_SECRET="votre-api-secret-production-hex"

# Callback public (Render) — même URL sandbox et prod
FLEXPAY_CALLBACK_URL="https://mobembo-api.onrender.com/api/payments/webhook/flexpay"
# Clés callback sandbox FreshPay (webhook chiffré AES + signature HMAC)
FLEXPAY_CALLBACK_AES_KEY="votre-cle-aes-16-caracteres"
FLEXPAY_CALLBACK_HMAC_KEY="votre-cle-hmac-16-caracteres"
# Optionnel — ancien mode header secret en clair
FLEXPAY_WEBHOOK_SECRET=""
BOOKING_PENDING_TTL_MINUTES=10


