# Supabase — Session pooler (port 5432) : migrations + dev local
# Remplacer [REGION] par la région affichée dans Supabase → Connect (ex: eu-west-1)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD-URL-ENCODED]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"
# En prod serverless (Render/Vercel runtime) : port 6543 + ?pgbouncer=true&connection_limit=1
JWT_SECRET="replace-with-a-strong-secret"
API_PORT=4000
FRONTEND_ORIGIN="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000,https://ton-frontend.com"
PUBLIC_API_BASE_URL="http://localhost:4000"
# --- FlexPay SANDBOX (tests actuels) — API v1 ---
FLEXPAY_BASE_URL="https://api.gofreshpay.com/api/v1/gateway"
FLEXPAY_MERCHANT_ID="votre-api-key-sandbox-uuid"
FLEXPAY_MERCHANT_SECRET="votre-api-secret-sandbox"

# --- FlexPay PRODUCTION (plus tard) — API v5 PayDRC ---
# FLEXPAY_BASE_URL="https://paydrc.gofreshbakery.net/api/v5/"
# FLEXPAY_MERCHANT_ID="votre-api-key-production-hex"
# FLEXPAY_MERCHANT_SECRET="votre-api-secret-production-hex"

# Callback public (Render) — même URL sandbox et prod
FLEXPAY_CALLBACK_URL="https://mobembo-api.onrender.com/api/payments/webhook/flexpay"
FLEXPAY_WEBHOOK_SECRET=""
BOOKING_PENDING_TTL_MINUTES=10


