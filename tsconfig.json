{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@prisma/client": ["./node_modules/@prisma/client"],
      "@prisma/client/*": ["./node_modules/@prisma/client/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
